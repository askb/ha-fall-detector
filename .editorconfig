root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4

[*.{yaml,yml}]
indent_size = 2

[*.json]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.{toml,cfg,ini}]
indent_size = 4

[Makefile]
indent_style = tab

[Dockerfile*]
indent_size = 4
